# --- App ---
# Public base URL of the app. Test environment: https://koda.orgusaar.ee
# (reverse proxy / Cloudflare / Unraid routes this domain to the app container).
APP_URL=https://koda.orgusaar.ee

# --- Database ---
# Inside Docker Compose the host is "postgres"; for local (non-Docker) dev use "localhost".
DATABASE_URL=postgresql://koda:koda_password@postgres:5432/koda

# Used by docker-compose.yml to configure the postgres container.
POSTGRES_USER=koda
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=koda

# --- Merge-ready import (Docker/Unraid) ---
# Host directory bind-mounted to /app/data/import in the app container. Put the
# structured v0.9.4 .xlsx files plus taxonomy .txt here; QA reports are
# written to its reports/ subfolder. Defaults to ./data/import for local compose.
# On Unraid use: KODA_IMPORT_DIR=/mnt/user/appdata/koda/import
KODA_IMPORT_DIR=./data/import

# --- Admin ---
# Simple MVP authentication: one admin account, password from env.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Crawler ---
CRAWLER_ENABLED=false
# Max listing pages to fetch per source (pagination depth).
CRAWLER_MAX_PAGES=5
# Whether to fetch full article bodies (slower, one request per article).
CRAWLER_FETCH_BODY=true
# Max article bodies to fetch per run (politeness cap).
CRAWLER_MAX_BODY_FETCHES=100
# Delay between requests in milliseconds.
CRAWLER_DELAY_MS=1000

# --- AI (designed in, not used in MVP) ---
AI_ENABLED=false
OPENAI_API_KEY=
