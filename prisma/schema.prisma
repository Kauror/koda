generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  opinion
  archive_opinion
  news
  currently_handled
  service
  event
  achievement
  unknown
}

/// Which merge-ready workbook a ContentItem was imported from.
/// Distinct from SourceType (kept for crawler/seed compatibility).
enum SourceDataset {
  web
  opinions
  annual_reports
  toovoidud
}

enum TagType {
  sector
  interest
  size
  activity
  region
  service
  // Merge-ready taxonomy (v1 Koda data model). These come from the cleaned
  // filter_*_merge fields and are the authoritative taxonomy after import.
  // The older sector/interest/activity/size tags stay for compatibility.
  valdkond // topic     -> filter_valdkonnad_merge
  tegevusala // sector   -> filter_tegevusala_merge
  tapsustus // provisional detail -> filter_tapsustus_merge_provisional
  oigusakt // confirmed law tags -> law_tags_confirmed
}

enum RelationType {
  main
  history
  related
}

/// How one ContentItem supports/relates to another (evidence graph).
enum EvidenceLinkType {
  supporting_opinion // public result -> opinion-file evidence
  annual_context // public result -> annual report context
  topic_history // public result -> earlier item on the same topic
  duplicate_canonical // duplicate row -> its canonical row
  achievement_enrichment // achievement row -> its enrichment record source
  // v1 cross-layer relation types (koda_content_links_v1.xlsx public_related_links).
  same_policy_thread // two layers in the same canonical policy thread
  public_explanation // opinion/work-win -> news that publicly explains it
  achieved_result // opinion/news -> the resulting work-win
  source_evidence // content -> its source/evidence row
  related_work_win // related töövõit ("Seotud töövõit")
  related_opinion // related Koda opinion ("Koja seisukoht")
  related_news // related explanatory news ("Selgitav uudis")
  background_context // general related background
}

model ContentItem {
  id           String     @id @default(cuid())
  sourceUrl    String?
  // canonicalUrl is optional now: opinion/annual rows have no public URL.
  // Still unique where present (Postgres allows many NULLs under a unique index).
  canonicalUrl String?    @unique
  title        String
  displayTitle String?
  date         DateTime?
  sourceType   SourceType @default(unknown)
  bodyText     String?
  excerpt      String?
  summary      String?
  contentHash  String?
  scrapedAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isHidden     Boolean    @default(false)
  isEvergreen  Boolean    @default(false)
  manualWeight Int        @default(0)
  language     String     @default("et")

  // --- Merge-ready import fields (v1 Koda source-layer data model) ---
  // Idempotency key: the stable external content ID from the source workbook
  // (e.g. WEB000001, WRK000059, ACH000007, OPINION-0001, AR-2014-001).
  externalId         String?        @unique
  sourceDataset      SourceDataset? // web | opinions | annual_reports
  sourceLayer        String? // koda_news, koda_public_opinion, koda_achievement, koda_workgroup_context, opinion_file, annual_report, ...
  sourceTypeDetail   String? // meie_uudis, toovoit, opinion_file, annual_report_policy_context, ...
  sourceFileName     String? // source_input_file / file_name / source_file
  sourceSection      String? // source_section
  sourcePageLocation String? // source_page_or_location (annual reports)
  reportYear         Int? // annual report_year
  year               Int? // calendar year of the content

  kodaPosition     String? // koda_position_or_impact_et
  companyRelevance String? // company_relevance_et
  sourceEvidence   String? // source_evidence_short / source_evidence
  outcomeStatus    String? // outcome_status / outcome_status_merge

  // Status / gating fields (copied verbatim from the merge-ready workbook).
  importStatus        String? // import_status_merge
  publicDisplayStatus String? // public_display_merge
  importAction        String? // v0.9.4 import_action / enrichment_public
  publicDisplayAllowed Boolean? // v0.9.4 public_display_allowed
  publicDisplayRole   String? // v0.9.4 public_display_role
  mergeReadiness      String? // merge_readiness
  mergeNotes          String? // merge_notes
  extractionQuality   String? // extraction_quality / text_extraction_quality
  needsHumanReview    Boolean @default(false) // needs_human_review_merge
  numericClaimNeedsReview Boolean @default(false)
  reviewReason        String?
  publicPriority      String? // high | medium | low
  sourceQualityFlag   String?
  classificationConfidence String?

  // Derived operational visibility: true only when the row passes all the
  // conservative public gating rules. isHidden mirrors !isPublic so the
  // existing search (which filters on isHidden=false) shows only public rows.
  isPublic Boolean @default(false)

  // Taxonomy snapshots from the merge fields (also materialised as Tags).
  primaryCategory     String? // primary_category / primary_category_merge
  secondaryCategories String? // secondary_categories
  topicGroupCandidate String? // topic_group_candidate
  topicPrimary        String?
  topicSecondary      String?
  activityPrimary     String?
  activitySecondary   String?
  sectorScope         String?
  situationTags       String?
  lawTagsConfirmed    String?
  lawTagsCandidate    String?
  lawSearchAllowed    Boolean @default(false)

  // --- Recipient / ministry metadata (taxonomy v2.1.6) ---
  // Metadata ONLY: the recipient/ministry is an advanced filter dimension and
  // must NEVER set or override topic_primary / topic classification.
  recipientRaw                         String? // recipient_raw (verbatim)
  recipientNormalized                  String? // recipient_normalized
  recipientFilterGroup                 String? // recipient_filter_group (the filterable bucket)
  recipientType                        String? // recipient_type (ministry | agency | ...)
  recipientSecondary                   String? // recipient_secondary
  recipientNormalizationReviewRequired Boolean @default(false) // recipient_normalization_review_required

  // Duplicate / canonical linkage.
  canonicalContentId String? // canonical_content_id (external id of the canonical row)
  duplicateStatus    String? // unique | possible_duplicate | ...

  // --- v1 app-import fields (koda_*_v1 slim import sheets) ---
  // Web visibility / ranking (null for opinions/töövõidud).
  contentRoleFinal              String? // content_role_final / content_role
  publicActivityFilterTags      String? // public_activity_filter_tags (search/ranking; cross-sector kept)
  publicActivityDisplayTags     String? // public_activity_display_tags (UI; cross-sector stripped)
  publicSectorPageAllowed       String? // TRUE | LIMITED | FALSE
  sectorResultEligibility       String? // sector_result_eligibility
  generalSearchEligibility      String? // general_search_eligibility
  recommendedAppVisibilityFinal String? // recommended_app_visibility_final
  publicSectorRankScore         Int? // public_sector_rank_score
  generalSearchRankScore        Int? // general_search_rank_score

  // Date safety (töövõidud carry precision/confidence/basis; web carries confidence).
  displayDatePrecision String? // day | month | year
  dateConfidence       String? // high | medium | low | unverified
  dateBasis            String? // machine reason for the date
  effectiveDate        DateTime? // legal effective date — NOT the achievement date
  deadlineDate         DateTime? // future compliance/deadline date

  // Töövõidu value fields (rendered on the achievement detail page).
  whatChangedEt       String? // what_changed_ee
  kodaRoleEt          String? // koda_role_ee
  businessValueEt     String? // business_value_ee
  beforeAfterEt       String? // before_after_ee
  workWinTypePrimary  String? // work_win_type_primary
  workWinTypeSecondary String? // work_win_type_secondary

  // Policy-thread identity (preserved so one thread can span opinion/news/work-win).
  canonicalPolicyThreadId String? // canonical_policy_thread_id
  policyThreadId          String? // policy_thread_id (if distinct)

  // --- v1.2 töövõidud nesting / timeline fields (koda_toovoidud_v1_5 slim) ---
  // These describe how a töövõit row relates to others so series/timeline rows
  // are NOT shown as duplicate flat cards. All nullable; legacy/non-töövõit rows
  // leave them null (importer defaults töövõit rows missing display_type to
  // standalone_card / row_origin original_90_locked). See src/lib/work-win-nesting.ts.
  rowOrigin         String? // original_90_locked | phase2_new_standalone | phase2_series_nested
  displayType       String? // standalone_card | nested_under_existing_card | nested_under_new_series_card | timeline_item_in_policy_thread
  parentToovoitId   String? // parent_toovoit_id — references an existing (original-90) toovoit externalId
  parentCandidateId String? // parent_candidate_id — new Phase 2 series/backfill parent (may be a thread key, not an imported id)
  policyThreadKey   String? // policy_thread_key — stable key grouping a policy-thread timeline
  policyThreadTitle String? // policy_thread_title — readable thread name
  timelineYear      Int? // timeline_year — year this timeline item represents
  timelineStage     String? // timeline_stage — proposal | riigikogu_adoption | final_entry_into_force | ...

  // --- Admin-owned override fields ---
  // The merge-ready import is the source of truth for the imported fields above
  // and overwrites them on every re-run. These override fields are NEVER written
  // by the import, so admin edits survive re-imports. Readers (search/UI) should
  // prefer the override when set, e.g. adminDisplayTitleOverride ?? displayTitle.
  adminDisplayTitleOverride String?
  adminSummaryOverride      String?
  adminTextOverride         String?
  adminVisibilityOverride   Boolean? // null = follow import gating; true/false = force public/hidden
  adminHiddenReason         String?
  adminReviewNote           String?

  // AI-ready fields, unused while AI_ENABLED=false.
  // embedding is a plain float array for now; switch to pgvector when AI search lands.
  embedding         Float[]
  aiSummary         String?
  aiRelevanceReason String?
  aiKeywords        String[]
  aiLastGeneratedAt DateTime?
  aiModel           String?
  aiReviewStatus    String?

  tags         ContentTag[]
  topicGroups  ContentTopicGroup[]
  mainOfGroups TopicGroup[]        @relation("TopicGroupMainItem")
  clicks       SearchResultClick[]

  // Evidence graph: links where this item is the public result (from) or the
  // supporting/duplicate target (to).
  evidenceLinksFrom ContentEvidenceLink[] @relation("EvidenceFrom")
  evidenceLinksTo   ContentEvidenceLink[] @relation("EvidenceTo")
  adminDrafts       AdminContentDraft[]

  // Achievement enrichment (1:1) for canonical töövõit rows. The standalone
  // enrichment workbook never becomes its own content row – it lives here.
  achievementEnrichment AchievementEnrichment?

  @@index([contentHash])
  @@index([date])
  @@index([isHidden])
  @@index([isPublic])
  @@index([sourceDataset])
  @@index([sourceLayer])
  @@index([importAction])
  @@index([publicDisplayAllowed])
  @@index([lawSearchAllowed])
  @@index([recipientFilterGroup])
  @@index([canonicalPolicyThreadId])
  @@index([parentToovoitId])
  @@index([parentCandidateId])
  @@index([policyThreadKey])
  @@index([displayType])
}

model TopicGroup {
  id                String  @id @default(cuid())
  title             String
  slug              String  @unique
  summary           String?
  mainContentItemId String?
  manualWeight      Int     @default(0)
  isEvergreen       Boolean @default(false)
  isHidden          Boolean @default(false)
  whyItMattersText  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mainContentItem ContentItem?        @relation("TopicGroupMainItem", fields: [mainContentItemId], references: [id], onDelete: SetNull)
  tags            TopicGroupTag[]
  contentItems    ContentTopicGroup[]
  clicks          SearchResultClick[]
}

model Tag {
  id   String  @id @default(cuid())
  type TagType
  name String
  slug String

  contentItems ContentTag[]
  topicGroups  TopicGroupTag[]

  @@unique([type, slug])
}

model ContentTag {
  contentItemId String
  tagId         String
  weight        Float  @default(1)

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentItemId, tagId])
}

model TopicGroupTag {
  topicGroupId String
  tagId        String
  weight       Float  @default(1)

  topicGroup TopicGroup @relation(fields: [topicGroupId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([topicGroupId, tagId])
}

model ContentTopicGroup {
  contentItemId String
  topicGroupId  String
  relationType  RelationType @default(related)

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  topicGroup  TopicGroup  @relation(fields: [topicGroupId], references: [id], onDelete: Cascade)

  @@id([contentItemId, topicGroupId])
}

/// Admin-managed topic thread / timeline group. Unlike TopicGroup (which the
/// merge-ready import wipes and recreates on every run), this is admin-owned
/// configuration: the import NEVER touches ContentThread/ContentThreadItem, so
/// threads survive re-imports. Members are referenced by the stable
/// ContentItem.externalId (NOT the churning cuid) — see ContentThreadItem.
model ContentThread {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String?
  primaryTopic  String? // valdkond (topic) — free label/slug, admin-owned
  primarySector String? // tegevusala (sector) — optional
  status        String   @default("draft") // draft | internal | public
  featured      Boolean  @default(false)
  sortPriority  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items ContentThreadItem[]

  @@index([status])
}

/// One content item attached to a ContentThread. Deliberately has NO relation to
/// ContentItem: the destructive import deletes+recreates ContentItem rows, so a
/// cascade FK would delete these on import and a restrict FK would block it.
/// `contentExternalId` is the stable ContentItem.externalId, resolved at read
/// time (same soft-reference pattern as DataReviewDecision.contentExternalId).
model ContentThreadItem {
  id                String   @id @default(cuid())
  threadId          String
  contentExternalId String // stable ContentItem.externalId (no FK on purpose)
  role              String? // background | opinion | work_win | news_update | evidence | milestone
  note              String?
  sortOrder         Int      @default(0)
  isAnchor          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  thread ContentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, contentExternalId])
  @@index([contentExternalId])
  @@index([threadId])
}

model SearchSession {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  selectedSector     String?
  selectedSize       String?
  selectedInterests  String[]
  selectedActivities String[]
  anonymizedIpHash   String?
  userAgentHash      String?

  clicks SearchResultClick[]

  @@index([createdAt])
}

model SearchResultClick {
  id              String   @id @default(cuid())
  searchSessionId String
  contentItemId   String?
  topicGroupId    String?
  clickedAt       DateTime @default(now())

  searchSession SearchSession @relation(fields: [searchSessionId], references: [id], onDelete: Cascade)
  contentItem   ContentItem?  @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  topicGroup    TopicGroup?   @relation(fields: [topicGroupId], references: [id], onDelete: SetNull)
}

model SiteText {
  id          String   @id @default(cuid())
  key         String   @unique
  valueEt     String
  description String?
  group       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
}

model SearchAlias {
  id              String   @id
  alias           String
  normalizedAlias String   @unique
  canonicalLabel  String
  type            String
  targetSlug      String?
  targetKind      String
  weight          Int
  language        String   @default("et")
  sourceBasis     Json?
  notes           String?
  isPublic        Boolean  @default(true)
  intent          String?
  expandedTerms   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([targetKind])
  @@index([targetSlug])
  @@index([type])
  @@index([weight])
  @@index([isPublic])
}

/// Online admin review decisions for local data-bundle taxonomy suggestions.
/// These rows are review notes/proposals only: saving a decision must never
/// update ContentItem taxonomy, generated bundle JSONL, or source Excel files.
model DataReviewDecision {
  id                String  @id @default(cuid())
  candidateId       String  @unique
  contentExternalId String?
  contentTitle      String?
  contentUrl        String?
  decision          String

  approvedValdkonnad     Json?
  approvedTegevusalad    Json?
  approvedTapsustused    Json?
  approvedPublicPriority Int?
  approvedSectorWeight   Float?
  approvedTopicWeight    Float?
  approvedGeneralWeight  Float?

  reviewerName        String?
  reviewerNote        String?
  sourceCandidateJson Json
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([decision])
  @@index([contentExternalId])
  @@index([reviewedAt])
}

model AdminContentOverride {
  id                String   @id @default(cuid())
  contentExternalId String   @unique
  contentItemId     String?
  titleOverride     String?
  summaryOverride   String?
  textOverride      String?
  visibilityOverride Boolean?
  hiddenReason      String?
  topicPrimary      String?
  topicSecondary    String?
  activityPrimary   String?
  activitySecondary String?
  publicActivityFilterTags  String?
  publicActivityDisplayTags String?
  publicSectorPageAllowed   String?
  updatedBy         String?
  publishedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([contentExternalId])
  @@index([visibilityOverride])
}

model AdminContentDraft {
  id                String   @id @default(cuid())
  contentExternalId String   @unique
  contentItemId     String?
  titleOverride     String?
  summaryOverride   String?
  textOverride      String?
  visibilityOverride Boolean?
  hiddenReason      String?
  topicPrimary      String?
  topicSecondary    String?
  activityPrimary   String?
  activitySecondary String?
  publicActivityFilterTags  String?
  publicActivityDisplayTags String?
  publicSectorPageAllowed   String?
  reviewerNote      String?
  updatedBy         String?
  publishedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  contentItem ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)

  @@index([contentExternalId])
  @@index([publishedAt])
}

model AdminAuditLog {
  id                String   @id @default(cuid())
  action            String
  contentExternalId String?
  contentItemId     String?
  oldValues         Json?
  newValues         Json?
  actor             String?
  publishRunId      String?
  createdAt         DateTime @default(now())

  publishRun AdminPublishRun? @relation(fields: [publishRunId], references: [id], onDelete: SetNull)

  @@index([contentExternalId])
  @@index([action])
  @@index([createdAt])
  @@index([publishRunId])
}

model AdminPublishRun {
  id             String    @id @default(cuid())
  kind           String
  status         String    @default("started")
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  actor          String?
  validationJson Json?
  reportJson     Json?
  backupName     String?
  errorSummary   String?

  auditLogs AdminAuditLog[]

  @@index([kind])
  @@index([status])
  @@index([startedAt])
}

/// Evidence graph linking a public result to its supporting opinions, annual
/// context, topic history, duplicate/canonical rows and achievement enrichment.
model ContentEvidenceLink {
  id            String           @id @default(cuid())
  fromContentId String
  toContentId   String
  linkType      EvidenceLinkType
  note          String?
  createdAt     DateTime         @default(now())

  // v1 relation metadata (from koda_content_links_v1.xlsx public_related_links).
  relationRole            String? // relationship_role (public_explanation, achieved_result, ...)
  relationLabelEt         String? // app_relation_label_ee (Koja seisukoht / Selgitav uudis / Seotud töövõit)
  linkConfidence          String? // high | curated_medium
  linkBasis               String? // link_basis (provenance)
  canonicalPolicyThreadId String? // policy thread the relation belongs to
  sortPriority            Int? // sort_priority for ordering related cards

  from ContentItem @relation("EvidenceFrom", fields: [fromContentId], references: [id], onDelete: Cascade)
  to   ContentItem @relation("EvidenceTo", fields: [toContentId], references: [id], onDelete: Cascade)

  @@unique([fromContentId, toContentId, linkType])
  @@index([toContentId])
  @@index([canonicalPolicyThreadId])
}

/// Achievement (töövõit) enrichment. One row per canonical web achievement
/// ContentItem. Populated by left-joining the standalone töövõidud enrichment
/// workbook onto the 76 canonical achievement rows – it never creates content
/// rows of its own.
model AchievementEnrichment {
  id            String @id @default(cuid())
  contentItemId String @unique

  // Source identity from the standalone enrichment workbook (A0001-style id).
  standaloneAchievementId String?
  matchKey                String? // normalized title key used for the join
  matchPriority           String? // 1_title_url_year | 2_title_url
  enrichmentStatus        String? // achievement_enrichment_status
  rowMergeRole            String? // enrichment_only (sanity marker)

  // Enrichment payload.
  numericImpactStatement    String?
  kodaRole                  String?
  valueType                 String?
  affectedCompanyTypes      String?
  affectedBusinessFunctions String?
  regulatoryArea            String?
  primaryTopic              String?
  secondaryTopics           String?
  outcomeStatus             String?
  confidence                String?
  sourceEvidence            String?
  indexNote                 String?

  importedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
}

/// One run of the Koda.ee live ingestion. Created only in staging mode; dry-run
/// writes nothing. Ingestion never mutates ContentItem and never publishes.
model IngestionRun {
  id              String    @id @default(cuid())
  source          String // koda_ee
  mode            String // dry_run | staging
  status          String    @default("started") // started | completed | failed
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  pagesDiscovered Int       @default(0)
  pagesFetched    Int       @default(0)
  itemsCreated    Int       @default(0)
  itemsUpdated    Int       @default(0)
  itemsSkipped    Int       @default(0)
  itemsFailed     Int       @default(0)
  errorSummary    String?
  createdAt       DateTime  @default(now())

  stagingItems IngestionStagingItem[]

  @@index([source])
  @@index([status])
  @@index([startedAt])
}

/// A single fetched/parsed public Koda.ee page held in the review staging layer.
/// Never public, never written into ContentItem by ingestion. `matchedContentItemId`
/// is a soft reference (no FK) so it can never block or cascade onto ContentItem.
model IngestionStagingItem {
  id                       String    @id @default(cuid())
  runId                    String?
  source                   String // koda_ee
  canonicalUrl             String
  urlHash                  String    @unique // sha256(canonicalUrl) — safe unique key
  contentHash              String?
  title                    String?
  summary                  String?
  bodyText                 String?
  publishedAt              DateTime?
  detectedSourceType       String? // news | opinion | achievement | event | other
  detectedValdkonnad       Json?
  detectedTegevusalad      Json?
  detectedTapsustused      Json?
  detectedLaws             Json?
  classificationConfidence String? // high | medium | low
  reviewStatus             String    @default("new") // new | matched_existing | needs_review | approved | rejected | ignored
  matchedContentItemId     String?
  rawMetadata              Json?
  fetchStatus              String? // ok | failed
  errorMessage             String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  run IngestionRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([reviewStatus])
  @@index([detectedSourceType])
  @@index([publishedAt])
  @@index([runId])
  @@index([canonicalUrl])
}
