generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  opinion
  archive_opinion
  news
  currently_handled
  service
  event
  achievement
  unknown
}

/// Which merge-ready workbook a ContentItem was imported from.
/// Distinct from SourceType (kept for crawler/seed compatibility).
enum SourceDataset {
  web
  opinions
  annual_reports
  toovoidud
}

enum TagType {
  sector
  interest
  size
  activity
  region
  service
  // Merge-ready taxonomy (v1 Koda data model). These come from the cleaned
  // filter_*_merge fields and are the authoritative taxonomy after import.
  // The older sector/interest/activity/size tags stay for compatibility.
  valdkond // topic     -> filter_valdkonnad_merge
  tegevusala // sector   -> filter_tegevusala_merge
  tapsustus // provisional detail -> filter_tapsustus_merge_provisional
  oigusakt // confirmed law tags -> law_tags_confirmed
}

enum RelationType {
  main
  history
  related
}

/// How one ContentItem supports/relates to another (evidence graph).
enum EvidenceLinkType {
  supporting_opinion // public result -> opinion-file evidence
  annual_context // public result -> annual report context
  topic_history // public result -> earlier item on the same topic
  duplicate_canonical // duplicate row -> its canonical row
  achievement_enrichment // achievement row -> its enrichment record source
}

model ContentItem {
  id           String     @id @default(cuid())
  sourceUrl    String?
  // canonicalUrl is optional now: opinion/annual rows have no public URL.
  // Still unique where present (Postgres allows many NULLs under a unique index).
  canonicalUrl String?    @unique
  title        String
  displayTitle String?
  date         DateTime?
  sourceType   SourceType @default(unknown)
  bodyText     String?
  excerpt      String?
  summary      String?
  contentHash  String?
  scrapedAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isHidden     Boolean    @default(false)
  isEvergreen  Boolean    @default(false)
  manualWeight Int        @default(0)
  language     String     @default("et")

  // --- Merge-ready import fields (v1 Koda source-layer data model) ---
  // Idempotency key: the stable external content ID from the source workbook
  // (e.g. WEB000001, WRK000059, ACH000007, OPINION-0001, AR-2014-001).
  externalId         String?        @unique
  sourceDataset      SourceDataset? // web | opinions | annual_reports
  sourceLayer        String? // koda_news, koda_public_opinion, koda_achievement, koda_workgroup_context, opinion_file, annual_report, ...
  sourceTypeDetail   String? // meie_uudis, toovoit, opinion_file, annual_report_policy_context, ...
  sourceFileName     String? // source_input_file / file_name / source_file
  sourceSection      String? // source_section
  sourcePageLocation String? // source_page_or_location (annual reports)
  reportYear         Int? // annual report_year
  year               Int? // calendar year of the content

  kodaPosition     String? // koda_position_or_impact_et
  companyRelevance String? // company_relevance_et
  sourceEvidence   String? // source_evidence_short / source_evidence
  outcomeStatus    String? // outcome_status / outcome_status_merge

  // Status / gating fields (copied verbatim from the merge-ready workbook).
  importStatus        String? // import_status_merge
  publicDisplayStatus String? // public_display_merge
  importAction        String? // v0.9.4 import_action / enrichment_public
  publicDisplayAllowed Boolean? // v0.9.4 public_display_allowed
  publicDisplayRole   String? // v0.9.4 public_display_role
  mergeReadiness      String? // merge_readiness
  mergeNotes          String? // merge_notes
  extractionQuality   String? // extraction_quality / text_extraction_quality
  needsHumanReview    Boolean @default(false) // needs_human_review_merge
  numericClaimNeedsReview Boolean @default(false)
  reviewReason        String?
  publicPriority      String? // high | medium | low
  sourceQualityFlag   String?
  classificationConfidence String?

  // Derived operational visibility: true only when the row passes all the
  // conservative public gating rules. isHidden mirrors !isPublic so the
  // existing search (which filters on isHidden=false) shows only public rows.
  isPublic Boolean @default(false)

  // Taxonomy snapshots from the merge fields (also materialised as Tags).
  primaryCategory     String? // primary_category / primary_category_merge
  secondaryCategories String? // secondary_categories
  topicGroupCandidate String? // topic_group_candidate
  topicPrimary        String?
  topicSecondary      String?
  activityPrimary     String?
  activitySecondary   String?
  sectorScope         String?
  situationTags       String?
  lawTagsConfirmed    String?
  lawTagsCandidate    String?
  lawSearchAllowed    Boolean @default(false)

  // Duplicate / canonical linkage.
  canonicalContentId String? // canonical_content_id (external id of the canonical row)
  duplicateStatus    String? // unique | possible_duplicate | ...

  // --- Admin-owned override fields ---
  // The merge-ready import is the source of truth for the imported fields above
  // and overwrites them on every re-run. These override fields are NEVER written
  // by the import, so admin edits survive re-imports. Readers (search/UI) should
  // prefer the override when set, e.g. adminDisplayTitleOverride ?? displayTitle.
  adminDisplayTitleOverride String?
  adminSummaryOverride      String?
  adminVisibilityOverride   Boolean? // null = follow import gating; true/false = force public/hidden
  adminReviewNote           String?

  // AI-ready fields, unused while AI_ENABLED=false.
  // embedding is a plain float array for now; switch to pgvector when AI search lands.
  embedding         Float[]
  aiSummary         String?
  aiRelevanceReason String?
  aiKeywords        String[]
  aiLastGeneratedAt DateTime?
  aiModel           String?
  aiReviewStatus    String?

  tags         ContentTag[]
  topicGroups  ContentTopicGroup[]
  mainOfGroups TopicGroup[]        @relation("TopicGroupMainItem")
  clicks       SearchResultClick[]

  // Evidence graph: links where this item is the public result (from) or the
  // supporting/duplicate target (to).
  evidenceLinksFrom ContentEvidenceLink[] @relation("EvidenceFrom")
  evidenceLinksTo   ContentEvidenceLink[] @relation("EvidenceTo")

  // Achievement enrichment (1:1) for canonical töövõit rows. The standalone
  // enrichment workbook never becomes its own content row – it lives here.
  achievementEnrichment AchievementEnrichment?

  @@index([contentHash])
  @@index([date])
  @@index([isHidden])
  @@index([isPublic])
  @@index([sourceDataset])
  @@index([sourceLayer])
  @@index([importAction])
  @@index([publicDisplayAllowed])
  @@index([lawSearchAllowed])
}

model TopicGroup {
  id                String  @id @default(cuid())
  title             String
  slug              String  @unique
  summary           String?
  mainContentItemId String?
  manualWeight      Int     @default(0)
  isEvergreen       Boolean @default(false)
  isHidden          Boolean @default(false)
  whyItMattersText  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mainContentItem ContentItem?        @relation("TopicGroupMainItem", fields: [mainContentItemId], references: [id], onDelete: SetNull)
  tags            TopicGroupTag[]
  contentItems    ContentTopicGroup[]
  clicks          SearchResultClick[]
}

model Tag {
  id   String  @id @default(cuid())
  type TagType
  name String
  slug String

  contentItems ContentTag[]
  topicGroups  TopicGroupTag[]

  @@unique([type, slug])
}

model ContentTag {
  contentItemId String
  tagId         String
  weight        Float  @default(1)

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentItemId, tagId])
}

model TopicGroupTag {
  topicGroupId String
  tagId        String
  weight       Float  @default(1)

  topicGroup TopicGroup @relation(fields: [topicGroupId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([topicGroupId, tagId])
}

model ContentTopicGroup {
  contentItemId String
  topicGroupId  String
  relationType  RelationType @default(related)

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  topicGroup  TopicGroup  @relation(fields: [topicGroupId], references: [id], onDelete: Cascade)

  @@id([contentItemId, topicGroupId])
}

model SearchSession {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  selectedSector     String?
  selectedSize       String?
  selectedInterests  String[]
  selectedActivities String[]
  anonymizedIpHash   String?
  userAgentHash      String?

  clicks SearchResultClick[]

  @@index([createdAt])
}

model SearchResultClick {
  id              String   @id @default(cuid())
  searchSessionId String
  contentItemId   String?
  topicGroupId    String?
  clickedAt       DateTime @default(now())

  searchSession SearchSession @relation(fields: [searchSessionId], references: [id], onDelete: Cascade)
  contentItem   ContentItem?  @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  topicGroup    TopicGroup?   @relation(fields: [topicGroupId], references: [id], onDelete: SetNull)
}

model SiteText {
  id          String   @id @default(cuid())
  key         String   @unique
  valueEt     String
  description String?
  group       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
}

/// Online admin review decisions for local data-bundle taxonomy suggestions.
/// These rows are review notes/proposals only: saving a decision must never
/// update ContentItem taxonomy, generated bundle JSONL, or source Excel files.
model DataReviewDecision {
  id                String  @id @default(cuid())
  candidateId       String  @unique
  contentExternalId String?
  contentTitle      String?
  contentUrl        String?
  decision          String

  approvedValdkonnad     Json?
  approvedTegevusalad    Json?
  approvedTapsustused    Json?
  approvedPublicPriority Int?
  approvedSectorWeight   Float?
  approvedTopicWeight    Float?
  approvedGeneralWeight  Float?

  reviewerName        String?
  reviewerNote        String?
  sourceCandidateJson Json
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([decision])
  @@index([contentExternalId])
  @@index([reviewedAt])
}

/// Evidence graph linking a public result to its supporting opinions, annual
/// context, topic history, duplicate/canonical rows and achievement enrichment.
model ContentEvidenceLink {
  id            String           @id @default(cuid())
  fromContentId String
  toContentId   String
  linkType      EvidenceLinkType
  note          String?
  createdAt     DateTime         @default(now())

  from ContentItem @relation("EvidenceFrom", fields: [fromContentId], references: [id], onDelete: Cascade)
  to   ContentItem @relation("EvidenceTo", fields: [toContentId], references: [id], onDelete: Cascade)

  @@unique([fromContentId, toContentId, linkType])
  @@index([toContentId])
}

/// Achievement (töövõit) enrichment. One row per canonical web achievement
/// ContentItem. Populated by left-joining the standalone töövõidud enrichment
/// workbook onto the 76 canonical achievement rows – it never creates content
/// rows of its own.
model AchievementEnrichment {
  id            String @id @default(cuid())
  contentItemId String @unique

  // Source identity from the standalone enrichment workbook (A0001-style id).
  standaloneAchievementId String?
  matchKey                String? // normalized title key used for the join
  matchPriority           String? // 1_title_url_year | 2_title_url
  enrichmentStatus        String? // achievement_enrichment_status
  rowMergeRole            String? // enrichment_only (sanity marker)

  // Enrichment payload.
  numericImpactStatement    String?
  kodaRole                  String?
  valueType                 String?
  affectedCompanyTypes      String?
  affectedBusinessFunctions String?
  regulatoryArea            String?
  primaryTopic              String?
  secondaryTopics           String?
  outcomeStatus             String?
  confidence                String?
  sourceEvidence            String?
  indexNote                 String?

  importedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contentItem ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
}

/// One run of the Koda.ee live ingestion. Created only in staging mode; dry-run
/// writes nothing. Ingestion never mutates ContentItem and never publishes.
model IngestionRun {
  id              String    @id @default(cuid())
  source          String // koda_ee
  mode            String // dry_run | staging
  status          String    @default("started") // started | completed | failed
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  pagesDiscovered Int       @default(0)
  pagesFetched    Int       @default(0)
  itemsCreated    Int       @default(0)
  itemsUpdated    Int       @default(0)
  itemsSkipped    Int       @default(0)
  itemsFailed     Int       @default(0)
  errorSummary    String?
  createdAt       DateTime  @default(now())

  stagingItems IngestionStagingItem[]

  @@index([source])
  @@index([status])
  @@index([startedAt])
}

/// A single fetched/parsed public Koda.ee page held in the review staging layer.
/// Never public, never written into ContentItem by ingestion. `matchedContentItemId`
/// is a soft reference (no FK) so it can never block or cascade onto ContentItem.
model IngestionStagingItem {
  id                       String    @id @default(cuid())
  runId                    String?
  source                   String // koda_ee
  canonicalUrl             String
  urlHash                  String    @unique // sha256(canonicalUrl) — safe unique key
  contentHash              String?
  title                    String?
  summary                  String?
  bodyText                 String?
  publishedAt              DateTime?
  detectedSourceType       String? // news | opinion | achievement | event | other
  detectedValdkonnad       Json?
  detectedTegevusalad      Json?
  detectedTapsustused      Json?
  detectedLaws             Json?
  classificationConfidence String? // high | medium | low
  reviewStatus             String    @default("new") // new | matched_existing | needs_review | approved | rejected | ignored
  matchedContentItemId     String?
  rawMetadata              Json?
  fetchStatus              String? // ok | failed
  errorMessage             String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  run IngestionRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([reviewStatus])
  @@index([detectedSourceType])
  @@index([publishedAt])
  @@index([runId])
  @@index([canonicalUrl])
}
